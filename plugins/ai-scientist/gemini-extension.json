{
  "name": "ai-scientist",
  "version": "2.1.0",
  "description": "Cross-host agentic research pipeline. 16 dedicated subagents with per-host model pinning (Gemini 3.1 Pro Preview for heavy roles + Gemini 3 Flash Preview for light), BFTS tree-search experiments, VLM figure review, slide generation, per-project MemPalace memory, and 9 pre-configured MCP servers. v2.0.0: Python orchestrator (mcp/lib/orchestrator/) drives all phases; SKILL.md is a thin intent router. Bundles canonical Sakana Python alongside lightweight host-native agents.",
  "contextFileName": "GEMINI.md",
  "mcpServers": {
    "ai-scientist": {
      "command": "python",
      "args": [
        "${extensionPath}/mcp/server.py",
        "--mode",
        "stdio"
      ],
      "env": {
        "AI_SCIENTIST_HOME": "${env:HOME}/.ai-scientist",
        "PYTHONPATH": "${extensionPath}/mcp/lib"
      },
      "cwd": "${extensionPath}"
    },
    "mempalace": {
      "command": "mempalace-mcp",
      "env": {
        "MEMPALACE_ROOT": "${env:HOME}/.ai-scientist/palace"
      }
    },
    "openalex": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/drAbreu/alex-mcp.git@4.1.0",
        "alex-mcp"
      ],
      "env": {
        "OPENALEX_MAILTO": "${env:OPENALEX_EMAIL}",
        "OPENALEX_RATE_PER_SEC": "10"
      }
    },
    "semanticscholar": {
      "command": "python",
      "args": [
        "${env:HOME}/.ai-scientist/external/semanticscholar-MCP-Server/semantic_scholar_server.py"
      ],
      "env": {
        "SEMANTIC_SCHOLAR_API_KEY": "${env:SEMANTIC_SCHOLAR_KEY}"
      }
    },
    "arxiv": {
      "command": "uvx",
      "args": ["arxiv-mcp-server"]
    },
    "biorxiv": {
      "command": "python",
      "args": [
        "${env:HOME}/.ai-scientist/external/bioRxiv-MCP-Server/biorxiv_server.py"
      ]
    },
    "pubmed": {
      "command": "npx",
      "args": ["-y", "pubmed-mcp"]
    },
    "annas-mcp": {
      "command": "npx",
      "args": ["-y", "annas-mcp", "mcp"],
      "env": {
        "ANNAS_BASE_URL": "${env:ANNAS_BASE_URL}",
        "ANNAS_DOWNLOAD_PATH": "${env:ANNAS_DOWNLOAD_PATH}",
        "ANNAS_SECRET_KEY": "${env:ANNAS_SECRET_KEY}"
      }
    },
    "fetcher": {
      "command": "npx",
      "args": ["-y", "fetcher-mcp"]
    }
  }
}
