{
  "plugins": {
    "ai-scientist": {
      "agents": {
        "ideator":             { "model": "opus",   "thinking_budget": 48000 },
        "codebase_scanner":    { "model": "sonnet", "thinking_budget": 8000 },
        "literature_searcher": { "model": "sonnet", "thinking_budget": 8000 },
        "hypothesizer":        { "model": "opus",   "thinking_budget": 64000 },
        "code_generator":      { "model": "opus",   "thinking_budget": 48000 },
        "experiment_runner":   { "model": "sonnet", "thinking_budget": 8000 },
        "plotter":             { "model": "sonnet", "thinking_budget": 8000 },
        "manuscript_writer":   { "model": "opus",   "thinking_budget": 48000 },
        "citator":             { "model": "sonnet", "thinking_budget": 8000 },
        "reviewer":            { "model": "opus",   "thinking_budget": 64000 },
        "meta_analyst":        { "model": "sonnet", "thinking_budget": 8000 },
        "fixer":               { "model": "sonnet", "thinking_budget": 16000 }
      },
      "codex_agents": {
        "ideator":             { "model": "gpt-5.5", "reasoning_effort": "xhigh", "max_output_tokens": 128000, "context_window": 1050000 },
        "codebase_scanner":    { "model": "gpt-5.4", "reasoning_effort": "high",  "max_output_tokens": 16384 },
        "literature_searcher": { "model": "gpt-5.4", "reasoning_effort": "high",  "max_output_tokens": 16384 },
        "hypothesizer":        { "model": "gpt-5.5", "reasoning_effort": "xhigh", "max_output_tokens": 128000, "context_window": 1050000 },
        "code_generator":      { "model": "gpt-5.5", "reasoning_effort": "xhigh", "max_output_tokens": 128000, "context_window": 1050000 },
        "experiment_runner":   { "model": "gpt-5.4", "reasoning_effort": "high",  "max_output_tokens": 16384 },
        "plotter":             { "model": "gpt-5.4", "reasoning_effort": "high",  "max_output_tokens": 16384 },
        "manuscript_writer":   { "model": "gpt-5.5", "reasoning_effort": "xhigh", "max_output_tokens": 128000, "context_window": 1050000 },
        "citator":             { "model": "gpt-5.4", "reasoning_effort": "high",  "max_output_tokens": 16384 },
        "reviewer":            { "model": "gpt-5.5", "reasoning_effort": "xhigh", "max_output_tokens": 128000, "context_window": 1050000 },
        "meta_analyst":        { "model": "gpt-5.4", "reasoning_effort": "high",  "max_output_tokens": 16384 },
        "fixer":               { "model": "gpt-5.4", "reasoning_effort": "high",  "max_output_tokens": 24576 }
      },
      "gemini_agents": {
        "ideator":             { "model": "gemini-3.1-pro-preview",   "thinking_level": "high",      "max_output_tokens": 65536, "context_window": 2000000 },
        "codebase_scanner":    { "model": "gemini-3-flash-preview",   "thinking_budget": 8192,        "max_output_tokens": 8192,  "context_window": 1000000 },
        "literature_searcher": { "model": "gemini-3-flash-preview",   "thinking_budget": 8192,        "max_output_tokens": 8192,  "context_window": 1000000 },
        "hypothesizer":        { "model": "gemini-3.1-pro-preview",   "thinking_level": "high",      "max_output_tokens": 65536, "context_window": 2000000 },
        "code_generator":      { "model": "gemini-3.1-pro-preview",   "thinking_level": "high",      "max_output_tokens": 65536, "context_window": 2000000 },
        "experiment_runner":   { "model": "gemini-3-flash-preview",   "thinking_budget": 8192,        "max_output_tokens": 8192,  "context_window": 1000000 },
        "plotter":             { "model": "gemini-3-flash-preview",   "thinking_budget": 8192,        "max_output_tokens": 8192,  "context_window": 1000000 },
        "manuscript_writer":   { "model": "gemini-3.1-pro-preview",   "thinking_level": "high",      "max_output_tokens": 65536, "context_window": 2000000 },
        "citator":             { "model": "gemini-3-flash-preview",   "thinking_budget": 8192,        "max_output_tokens": 8192,  "context_window": 1000000 },
        "reviewer":            { "model": "gemini-3.1-pro-preview",   "thinking_level": "high",      "max_output_tokens": 65536, "context_window": 2000000 },
        "meta_analyst":        { "model": "gemini-3-flash-preview",   "thinking_budget": 8192,        "max_output_tokens": 8192,  "context_window": 1000000 },
        "fixer":               { "model": "gemini-3-flash-preview",   "thinking_budget": 16384,       "max_output_tokens": 16384, "context_window": 1000000 }
      },
      "interactivity": "checkpoints",
      "auto_fix_max_rounds": 3,
      "fixer_max_rounds_per_phase": 3,
      "phases": {
        "codebase_scan": "auto",
        "novelty_check": "on",
        "plot_aggregation": "on",
        "citation_enrichment": { "enabled": true, "max_rounds": 5 },
        "self_review": "on",
        "latex_compile": "auto",
        "word_export": "auto",
        "visual_validation": "on",
        "knowledge_index": "on",
        "meta_analysis": "on"
      },
      "manuscript": {
        "latex_template": "aiscientist-default",
        "word_template": "arxiv-shared-1",
        "tone": "technical",
        "citation_density": "medium"
      },
      "literature": {
        "max_papers": 30,
        "year_floor": 2024,
        "fallback_year_floor": 2020,
        "min_unique_threshold": 10,
        "metadata_validation": "off",
        "openalex_rate_limit_per_second": 5,
        "max_wall_clock_seconds": 180,
        "per_source_time_budget_seconds": 60,
        "sources": {
          "openalex":         true,
          "arxiv":            true,
          "pubmed":           true,
          "biorxiv":          true,
          "semantic_scholar": "if_key_set",
          "annas_archive":    true,
          "consensus":        "if_key_set"
        }
      },
      "credentials": {
        "openalex_email": "${env:OPENALEX_EMAIL}",
        "semantic_scholar_key": "${env:SEMANTIC_SCHOLAR_KEY}"
      },
      "storage": {
        "knowledge_root": "~/.ai-scientist",
        "default_output_root": "./ai-scientist-output",
        "retain_completed_jobs_days": 90,
        "mempalace_path_template": "${output_dir}/.palace"
      },
      "memory": {
        "enabled": true,
        "per_project_db": true,
        "scope": "project",
        "isolation": "strict",
        "session_recall_on_start": true,
        "save_before_compact": true,
        "save_on_phase_complete": true,
        "save_on_agent_entry": true,
        "save_on_agent_exit": true,
        "agent_diaries": true,
        "wake_up_token_budget": 4000,
        "no_cross_project_leak": true
      },
      "experiment": {
        "timeout_seconds": 300,
        "venv_per_job": true,
        "max_dependency_install_attempts": 2,
        "use_bfts": false,
        "bfts_time_budget_minutes": 30,
        "bfts_config_path": "${plugin_root}/mcp/lib/v2/bfts_config.yaml"
      }
    }
  }
}
